<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="001-tables" author="alfred">
        <sqlFile path="db/changelog/migrations/001-tables.sql"/>
    </changeSet>

    <changeSet id="002-procedures" author="alfred" runOnChange="true">
        <sqlFile path="db/changelog/migrations/002-procedures.sql" splitStatements="false"/>
    </changeSet>

    <changeSet id="004-data" author="alfred" runOnChange="true">
        <sqlFile path="db/changelog/migrations/004-data.sql"/>
    </changeSet>

</databaseChangeLog>